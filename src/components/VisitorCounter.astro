---
---

<div class="visitor-counter" id="visitor-counter">
  <div class="onigiri-wrap">
    <div class="onigiri">
      <div class="onigiri-body">
        <div class="onigiri-nori"></div>
        <div class="onigiri-face">
          <span class="onigiri-eyes">• ᴗ •</span>
        </div>
      </div>
    </div>
  </div>
  <div class="counter-info">
    <span class="counter-label">おにぎりカウンター</span>
    <span class="counter-number" id="visitor-count">
      <span class="counting">...</span>
    </span>
    <span class="counter-suffix">人が遊びに来たよ！</span>
  </div>
</div>

<script>
  const countEl = document.getElementById('visitor-count');
  const sessionKey = 'visited-home';

  async function initCounter() {
    try {
      // 初回訪問ならカウントアップ
      if (!sessionStorage.getItem(sessionKey)) {
        const res = await fetch('/api/visitors', { method: 'POST' });
        const data = await res.json();
        sessionStorage.setItem(sessionKey, 'true');
        animateCount(data.visitors);
      } else {
        const res = await fetch('/api/visitors');
        const data = await res.json();
        animateCount(data.visitors);
      }
    } catch (e) {
      if (countEl) countEl.textContent = '0';
    }
  }

  function animateCount(target: number) {
    if (!countEl) return;
    let current = 0;
    const duration = 1000;
    const step = Math.max(1, Math.floor(target / 60));
    const interval = setInterval(() => {
      current += step;
      if (current >= target) {
        current = target;
        clearInterval(interval);
      }
      countEl.textContent = current.toLocaleString();
    }, duration / 60);
  }

  initCounter();
</script>

<style>
  .visitor-counter {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    background: linear-gradient(135deg, #fffef5 0%, #fff8e8 100%);
    border: 2px solid #f0e6c0;
    border-radius: 60px;
    padding: 0.5rem 1.4rem;
    max-width: 380px;
    margin: 0 auto 1.5rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    animation: fadeInUp 0.6s ease;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .onigiri-wrap {
    flex-shrink: 0;
  }

  .onigiri {
    position: relative;
    width: 42px;
    height: 42px;
    animation: bounce 2s ease-in-out infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
  }

  .onigiri-body {
    position: relative;
    width: 40px;
    height: 36px;
    background: #fff;
    border-radius: 50% 50% 45% 45% / 60% 60% 40% 40%;
    border: 2px solid #e0d5b5;
    clip-path: polygon(50% 0%, 100% 70%, 85% 100%, 15% 100%, 0% 70%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .onigiri-nori {
    position: absolute;
    bottom: 0;
    left: 15%;
    width: 70%;
    height: 40%;
    background: #2d2d2d;
    border-radius: 2px 2px 4px 4px;
  }

  .onigiri-face {
    position: absolute;
    top: 40%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }

  .onigiri-eyes {
    font-size: 0.5rem;
    color: #333;
    white-space: nowrap;
    letter-spacing: 1px;
  }

  .counter-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.3;
  }

  .counter-label {
    font-size: 0.65rem;
    color: #b8a070;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .counter-number {
    font-size: 1.4rem;
    font-weight: 800;
    color: #d4880f;
    font-family: 'Courier New', monospace;
    letter-spacing: 1px;
  }

  .counting {
    animation: pulse 1s ease infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .counter-suffix {
    font-size: 0.7rem;
    color: #a08850;
    font-weight: 500;
  }

  @media (max-width: 480px) {
    .visitor-counter {
      padding: 0.4rem 1rem;
      gap: 0.6rem;
    }
    .counter-number {
      font-size: 1.2rem;
    }
  }
</style>
