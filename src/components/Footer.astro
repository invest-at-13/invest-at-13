---
import { SITE_TITLE } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-brand">
			<a href="/invest-at-13/" class="footer-logo">
				<span>📊</span>
				<span>{SITE_TITLE}</span>
			</a>
			<p class="footer-tagline">13歳がAI・投資・ゲーム・料理を本気で語る</p>
		</div>

		<div class="footer-links">
			<div class="footer-col">
				<h4>ページ</h4>
				<ul>
					<li><a href="/invest-at-13/">ホーム</a></li>
					<li><a href="/invest-at-13/blog/">ブログ</a></li>
					<li><a href="/invest-at-13/about/">プロフィール</a></li>
				</ul>
			</div>
			<div class="footer-col">
				<h4>カテゴリー</h4>
				<ul>
					<li><a href="/invest-at-13/categories/ai/">🤖 AI活用</a></li>
					<li><a href="/invest-at-13/categories/investment/">📈 投資</a></li>
					<li><a href="/invest-at-13/categories/game/">🎮 ゲーム</a></li>
					<li><a href="/invest-at-13/categories/cooking/">🍳 料理</a></li>
					<li><a href="/invest-at-13/categories/gadget/">📱 ガジェット</a></li>
				</ul>
			</div>
		</div>
	</div>

	<div class="footer-bottom">
		<p>© {year} {SITE_TITLE}. All rights reserved.</p>
		<a href="/invest-at-13/rss.xml" class="rss-link">
			<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
				<path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
			</svg>
			RSS
		</a>
	</div>
</footer>

<style>
	.site-footer {
		background: var(--black);
		color: rgba(255,255,255,0.75);
		margin-top: 4rem;
	}

	.footer-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 3rem 1rem 2rem;
		display: flex;
		gap: 3rem;
		flex-wrap: wrap;
		justify-content: space-between;
	}

	.footer-brand {
		flex: 1;
		min-width: 200px;
	}

	.footer-logo {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--white);
		font-weight: 700;
		font-size: 1.1rem;
		text-decoration: none;
		margin-bottom: 0.5rem;
	}
	.footer-logo:hover { color: var(--accent); }

	.footer-tagline {
		font-size: 0.88rem;
		color: rgba(255,255,255,0.5);
		margin: 0;
		line-height: 1.5;
	}

	.footer-links {
		display: flex;
		gap: 3rem;
		flex-wrap: wrap;
	}

	.footer-col h4 {
		color: var(--white);
		font-size: 0.85rem;
		font-weight: 600;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		margin: 0 0 0.8rem 0;
	}

	.footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
	}

	.footer-col a {
		color: rgba(255,255,255,0.65);
		font-size: 0.9rem;
		text-decoration: none;
		transition: color 0.15s;
	}
	.footer-col a:hover { color: var(--white); }

	.footer-bottom {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 1.2rem 1rem;
		border-top: 1px solid rgba(255,255,255,0.1);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.footer-bottom p {
		margin: 0;
		font-size: 0.83rem;
		color: rgba(255,255,255,0.45);
	}

	.rss-link {
		display: flex;
		align-items: center;
		gap: 0.3rem;
		color: rgba(255,255,255,0.45);
		font-size: 0.83rem;
		text-decoration: none;
		transition: color 0.15s;
	}
	.rss-link:hover { color: var(--white); }

	@media (max-width: 600px) {
		.footer-inner { flex-direction: column; gap: 2rem; }
		.footer-links { gap: 2rem; }
	}
</style>
