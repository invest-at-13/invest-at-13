---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES, SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog');

	return CATEGORIES.map((cat) => {
		const categoryPosts = allPosts
			.filter((post) => post.data.category === cat.value)
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

		return {
			params: { category: cat.value },
			props: { category: cat, posts: categoryPosts },
		};
	});
}

const { category, posts } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={`${category.emoji} ${category.label} | ${SITE_TITLE}`}
			description={`${category.label}に関する記事一覧 — ${SITE_TITLE}`}
		/>
	</head>
	<body>
		<Header />

		<div class={`page-hero page-hero--${category.value}`}>
			<div class="page-hero-inner">
				<div class="category-icon">{category.emoji}</div>
				<h1>{category.label}</h1>
				<p>{posts.length} 件の記事</p>
			</div>
		</div>

		<!-- Other categories -->
		<div class="other-categories">
			<div class="other-cats-inner">
				<a href="/invest-at-13/blog/" class="other-cat-link">すべて</a>
				{CATEGORIES.filter(c => c.value !== category.value).map(cat => (
					<a href={`/invest-at-13/categories/${cat.value}/`} class="other-cat-link">
						{cat.emoji} {cat.label}
					</a>
				))}
			</div>
		</div>

		<main>
			{posts.length > 0 ? (
				<ul class="posts-list">
					{posts.map((post) => (
						<li class="post-item">
							<article class="post-card">
								{post.data.heroImage && (
									<a href={`/invest-at-13/blog/${post.id}/`} class="card-image-link" tabindex="-1" aria-hidden="true">
										<div class="card-image">
											<Image width={400} height={220} src={post.data.heroImage} alt={post.data.title} />
										</div>
									</a>
								)}
								<div class="card-body">
									<div class="card-meta">
										<time class="card-date" datetime={post.data.pubDate.toISOString()}>
											<FormattedDate date={post.data.pubDate} />
										</time>
									</div>
									<h2 class="card-title">
										<a href={`/invest-at-13/blog/${post.id}/`}>{post.data.title}</a>
									</h2>
									<p class="card-desc">{post.data.description}</p>
									<a href={`/invest-at-13/blog/${post.id}/`} class="read-more">
										続きを読む →
									</a>
								</div>
							</article>
						</li>
					))}
				</ul>
			) : (
				<div class="no-posts">
					<p>このカテゴリーにはまだ記事がありません。<br/>近日公開予定です！</p>
					<a href="/invest-at-13/blog/" class="back-link">ブログ一覧へ戻る</a>
				</div>
			)}
		</main>

		<Footer />
	</body>
</html>

<style>
	.page-hero {
		padding: 2.5rem 1rem 2rem;
		border-bottom: 1px solid var(--gray-light);
	}
	.page-hero-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}
	.page-hero--ai { background: linear-gradient(135deg, #f3f0ff 0%, #fafafa 100%); }
	.page-hero--investment { background: linear-gradient(135deg, #ecfdf5 0%, #fafafa 100%); }
	.page-hero--game { background: linear-gradient(135deg, #fff5f5 0%, #fafafa 100%); }
	.page-hero--cooking { background: linear-gradient(135deg, #fffbeb 0%, #fafafa 100%); }
	.page-hero--gadget { background: linear-gradient(135deg, #ecfeff 0%, #fafafa 100%); }

	.category-icon { font-size: 2.2rem; line-height: 1; margin-bottom: 0.2rem; }
	.page-hero h1 { font-size: 2rem; margin: 0 0 0.3rem; }
	.page-hero p { margin: 0; color: var(--gray); font-size: 0.9rem; }

	/* Other categories nav */
	.other-categories {
		background: var(--white);
		border-bottom: 1px solid var(--gray-light);
	}
	.other-cats-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0.6rem 1rem;
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}
	.other-cat-link {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		padding: 0.28rem 0.75rem;
		border-radius: var(--radius-full);
		font-size: 0.83rem;
		font-weight: 500;
		color: var(--gray-dark);
		background: var(--gray-lighter);
		border: 1px solid var(--gray-light);
		text-decoration: none;
		transition: all 0.15s;
	}
	.other-cat-link:hover {
		background: var(--accent-light);
		color: var(--accent);
		border-color: var(--accent);
	}

	/* Posts list — shared with blog/index */
	.posts-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	.post-item { width: 100%; }
	.post-card {
		background: var(--white);
		border-radius: var(--radius-md);
		border: 1px solid var(--gray-light);
		overflow: hidden;
		display: flex;
		transition: box-shadow 0.2s, transform 0.2s;
	}
	.post-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}
	.card-image-link { flex-shrink: 0; width: 260px; }
	.card-image {
		height: 100%;
		overflow: hidden;
		background: var(--gray-lighter);
	}
	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		display: block;
		transition: transform 0.3s;
	}
	.post-card:hover .card-image img { transform: scale(1.04); }
	.card-body {
		padding: 1.2rem 1.4rem;
		flex: 1;
		display: flex;
		flex-direction: column;
	}
	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 0.6rem;
	}
	.card-date { font-size: 0.82rem; color: var(--gray); }
	.card-title { font-size: 1.2rem; line-height: 1.4; margin: 0 0 0.6rem 0; }
	.card-title a { color: var(--black); text-decoration: none; }
	.card-title a:hover { color: var(--accent); }
	.card-desc {
		font-size: 0.9rem;
		color: var(--gray);
		line-height: 1.65;
		margin: 0 0 auto 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.read-more {
		margin-top: 0.9rem;
		font-size: 0.88rem;
		font-weight: 600;
		color: var(--accent);
		text-decoration: none;
		align-self: flex-start;
	}
	.read-more:hover { text-decoration: underline; }
	.no-posts {
		text-align: center;
		padding: 4rem 2rem;
		color: var(--gray);
		background: var(--gray-lighter);
		border-radius: var(--radius-md);
	}
	.no-posts p { margin: 0 0 1.2rem; line-height: 1.8; }
	.back-link {
		display: inline-flex;
		align-items: center;
		padding: 0.55rem 1rem;
		background: var(--accent);
		color: white;
		border-radius: var(--radius-full);
		font-size: 0.9rem;
		font-weight: 500;
		text-decoration: none;
	}
	.back-link:hover { background: var(--accent-dark); color: white; }

	@media (max-width: 640px) {
		.post-card { flex-direction: column; }
		.card-image-link { width: 100%; }
		.card-image img { height: 180px; }
		.card-body { padding: 1rem; }
		.card-title { font-size: 1.05rem; }
	}
</style>
