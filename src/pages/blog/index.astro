---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, CATEGORIES } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`ブログ | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<div class="page-hero">
			<div class="page-hero-inner">
				<h1>ブログ</h1>
				<p>全 {posts.length} 記事 — AI・投資・ゲーム・料理について書いています</p>
			</div>
		</div>

		<!-- Category filter -->
		<div class="filter-bar">
			<div class="filter-inner">
				<a href="/invest-at-13/blog/" class="filter-chip filter-chip--all active">
					すべて
				</a>
				{CATEGORIES.map(cat => (
					<a href={`/invest-at-13/categories/${cat.value}/`} class={`filter-chip filter-chip--${cat.value}`}>
						{cat.emoji} {cat.label}
					</a>
				))}
			</div>
		</div>

		<main>
			{posts.length > 0 ? (
				<ul class="posts-list">
					{posts.map((post) => {
						const catInfo = post.data.category
							? CATEGORIES.find(c => c.value === post.data.category)
							: null;
						return (
							<li class="post-item">
								<article class="post-card">
									{post.data.heroImage && (
										<a href={`/invest-at-13/blog/${post.id}/`} class="card-image-link" tabindex="-1" aria-hidden="true">
											<div class="card-image">
												<Image width={400} height={220} src={post.data.heroImage} alt={post.data.title} />
											</div>
										</a>
									)}
									<div class="card-body">
										<div class="card-meta">
											{catInfo && (
												<a href={`/invest-at-13/categories/${catInfo.value}/`} class={`category-badge ${catInfo.value}`}>
													{catInfo.emoji} {catInfo.label}
												</a>
											)}
											<time class="card-date" datetime={post.data.pubDate.toISOString()}>
												<FormattedDate date={post.data.pubDate} />
											</time>
										</div>
										<h2 class="card-title">
											<a href={`/invest-at-13/blog/${post.id}/`}>{post.data.title}</a>
										</h2>
										<p class="card-desc">{post.data.description}</p>
										<a href={`/invest-at-13/blog/${post.id}/`} class="read-more">
											続きを読む →
										</a>
									</div>
								</article>
							</li>
						);
					})}
				</ul>
			) : (
				<div class="no-posts">
					<p>まだ記事がありません。最初の記事をお楽しみに！</p>
				</div>
			)}
		</main>

		<Footer />
	</body>
</html>

<style>
	.page-hero {
		background: var(--gray-lighter);
		border-bottom: 1px solid var(--gray-light);
		padding: 2.5rem 1rem 2rem;
	}
	.page-hero-inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}
	.page-hero h1 {
		font-size: 2rem;
		margin: 0 0 0.4rem 0;
	}
	.page-hero p {
		margin: 0;
		color: var(--gray);
		font-size: 0.95rem;
	}

	/* Filter */
	.filter-bar {
		border-bottom: 1px solid var(--gray-light);
		background: var(--white);
		position: sticky;
		top: var(--header-height);
		z-index: 50;
	}
	.filter-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0.7rem 1rem;
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
	}
	.filter-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.3rem 0.85rem;
		border-radius: var(--radius-full);
		font-size: 0.83rem;
		font-weight: 500;
		text-decoration: none;
		border: 1px solid transparent;
		transition: all 0.15s;
	}
	.filter-chip--all {
		background: var(--gray-lighter);
		color: var(--gray-dark);
		border-color: var(--gray-light);
	}
	.filter-chip--all.active, .filter-chip--all:hover {
		background: var(--black);
		color: var(--white);
		border-color: var(--black);
	}
	.filter-chip--ai { background: #f3f0ff; color: var(--cat-ai); border-color: #ddd6fe; }
	.filter-chip--investment { background: #ecfdf5; color: var(--cat-investment); border-color: #a7f3d0; }
	.filter-chip--game { background: #fff5f5; color: var(--cat-game); border-color: #fecaca; }
	.filter-chip--cooking { background: #fffbeb; color: var(--cat-cooking); border-color: #fde68a; }
	.filter-chip--gadget { background: #ecfeff; color: var(--cat-gadget); border-color: #a5f3fc; }
	.filter-chip:hover { opacity: 0.8; }

	/* Posts list */
	.posts-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	.post-item { width: 100%; }

	.post-card {
		background: var(--white);
		border-radius: var(--radius-md);
		border: 1px solid var(--gray-light);
		overflow: hidden;
		display: flex;
		transition: box-shadow 0.2s, transform 0.2s;
	}
	.post-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}
	.card-image-link {
		flex-shrink: 0;
		width: 260px;
	}
	.card-image {
		height: 100%;
		overflow: hidden;
		background: var(--gray-lighter);
	}
	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		display: block;
		transition: transform 0.3s;
	}
	.post-card:hover .card-image img { transform: scale(1.04); }

	.card-body {
		padding: 1.2rem 1.4rem;
		flex: 1;
		display: flex;
		flex-direction: column;
	}
	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 0.6rem;
		flex-wrap: wrap;
	}
	.card-date {
		font-size: 0.82rem;
		color: var(--gray);
	}
	.card-title {
		font-size: 1.2rem;
		line-height: 1.4;
		margin: 0 0 0.6rem 0;
	}
	.card-title a {
		color: var(--black);
		text-decoration: none;
	}
	.card-title a:hover { color: var(--accent); }
	.card-desc {
		font-size: 0.9rem;
		color: var(--gray);
		line-height: 1.65;
		margin: 0 0 auto 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.read-more {
		margin-top: 0.9rem;
		font-size: 0.88rem;
		font-weight: 600;
		color: var(--accent);
		text-decoration: none;
		align-self: flex-start;
	}
	.read-more:hover { text-decoration: underline; }

	.no-posts {
		text-align: center;
		padding: 4rem 2rem;
		color: var(--gray);
		background: var(--gray-lighter);
		border-radius: var(--radius-md);
	}

	@media (max-width: 640px) {
		.post-card { flex-direction: column; }
		.card-image-link { width: 100%; }
		.card-image img { height: 180px; }
		.card-body { padding: 1rem; }
		.card-title { font-size: 1.05rem; }
	}
</style>
